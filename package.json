{
  "name": "circlefi",
  "version": "1.0.0",
  "description": "A decentralized rotating credit protocol on Hedera Hashgraph for the Hello Future Apex Hackathon 2026",
  "main": "index.js",
  "scripts": {
    "test": "npx hardhat test",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network hederaTestnet",
    "start": "cd frontend && npm run dev",
    "dev": "concurrently \"npx hardhat node\" \"npm run start\"",
    "audit": "npm audit && npm audit fix"
  },
  "keywords": [
    "hedera",
    "defi",
    "chit-fund",
    "rotating-credit",
    "smart-contracts",
    "ethereum",
    "solidity"
  ],
  "author": "CircleFi Team",
  "license": "MIT",
  "devDependencies": {
    "@hashgraph/sdk": "^2.40.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.8"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0"
  }
}
